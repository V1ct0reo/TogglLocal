@page "/analysis"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@implements IAsyncDisposable
@inject TogglAnalysis.Services.TogglService TogglService
@inject TogglAnalysis.Data.AppDbContext DbContext
@inject IJSRuntime JSRuntime
@using TogglAnalysis.Models
@using Microsoft.EntityFrameworkCore

<h3>Analysis</h3>

<div class="row mb-3 align-items-end">
    <div class="col-md-auto mb-2">
        <label class="form-label" style="font-size: 0.8rem; margin-bottom: 0;">Timeframe</label>
        <div class="input-group input-group-sm">
            <button class="btn btn-outline-secondary" @onclick="ShiftPrev" title="Previous Frame">&#9664;</button>
            <select class="form-select text-center" value="@SelectedTimeframe" @onchange="OnTimeframeSelectChanged" style="width: 140px; box-shadow: none;">
                <option value="LastWeek">Last Week</option>
                <option value="LastMonth">Last Month</option>
                <option value="LastQuarter">Last Quarter</option>
                <option value="ThisYear">This Year</option>
                <option value="Custom">Custom</option>
            </select>
            <button class="btn btn-outline-secondary" @onclick="ShiftNext" title="Next Frame">&#9654;</button>
        </div>
    </div>
    <div class="col-md-auto mb-2">
        <label class="form-label" style="font-size: 0.8rem; margin-bottom: 0;">Start Date</label>
        <input type="date" class="form-control form-control-sm" @bind-value="StartDate" @bind-value:after="OnCustomDateChanged" />
    </div>
    <div class="col-md-auto mb-2">
        <label class="form-label" style="font-size: 0.8rem; margin-bottom: 0;">End Date</label>
        <input type="date" class="form-control form-control-sm" @bind-value="EndDate" @bind-value:after="OnCustomDateChanged" />
    </div>
    <div class="col-md-auto mb-2">
        <button class="btn btn-primary btn-sm" @onclick="ApplyTimeframe">Load Data</button>
    </div>
</div>

@if (IsLoading)
{
    <div class="d-flex flex-column align-items-center justify-content-center my-5">
        <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" Style="width: 300px; margin-bottom: 20px;" />
        <p class="text-muted" style="font-family: 'Inter', sans-serif;">Analyzing your time data...</p>
    </div>
}
else if (TimeEntries == null)
{
    <p><em>Loading...</em></p>
}
else if (!TimeEntries.Any())
{
    <p>No entries found for this period.</p>
}
else
{
    <div class="card mb-5 shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
        <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center pt-4 px-4 pb-0">
            <h5 class="fw-bold mb-0 text-primary" style="font-family: 'Inter', sans-serif;">Project Trends</h5>
            <RadzenSelectBar Value="SelectedChartType" TValue="int" Size="ButtonSize.Small" ValueChanged="@OnChartTypeChanged">
                <Items>
                    <RadzenSelectBarItem Text="Stacked Bar" Value="1" />
                    <RadzenSelectBarItem Text="Line Chart" Value="2" />
                    <RadzenSelectBarItem Text="Stacked Area" Value="4" />
                    <RadzenSelectBarItem Text="Pie Chart" Value="3" />
                    <RadzenSelectBarItem Text="Scatter Plot" Value="5" />
                </Items>
            </RadzenSelectBar>
        </div>
        <div class="card-body p-4 bg-light">
            @if (SelectedChartType == 3)
            {
                <RadzenChart>
                    <RadzenPieSeries Data="@PieChartData" Title="Total Hours" CategoryProperty="ProjectName" ValueProperty="TotalHours">
                        <TooltipTemplate Context="data">
                            @{
                                var psh = (ProjectSummaryHours)data;
                                <div style="padding: 5px;">
                                    <strong style="display: block; margin-bottom: 5px;">@psh.ProjectName</strong>
                                    <span>Total: @FormatAsHours(psh.TotalHours)</span>
                                </div>
                            }
                        </TooltipTemplate>
                    </RadzenPieSeries>
                    <RadzenLegend Position="LegendPosition.Right" />
                </RadzenChart>
            }
            else
            {
                <div id="chart-scroll-wrapper" style="width: 100%; overflow-x: auto; overflow-y: hidden; position: relative;" class="border-bottom">
                    <div style="width: @(ChartWidthPercent)%; min-width: 100%; height: 400px; transition: width 0.1s linear;">
                        @if (SelectedChartType == 5)
                        {
                            <RadzenChart Style="width:100%; height:100%;">
                                @foreach (var projectName in ScatterChartData.Select(d => d.ProjectName).Distinct())
                                {
                                    <RadzenLineSeries Data="@ScatterChartData.Where(d => d.ProjectName == projectName)" 
                                                         CategoryProperty="XOffset" 
                                                         ValueProperty="Hours" 
                                                         Title="@projectName"
                                                         StrokeWidth="0">
                                        <ChildContent>
                                            <RadzenMarkers MarkerType="MarkerType.Circle" />
                                        </ChildContent>
                                        <TooltipTemplate Context="data">
                                            @{
                                                var se = (ScatterEntry)data;
                                                <div style="padding: 5px;">
                                                    <strong style="display: block; margin-bottom: 5px;">@se.ProjectName</strong>
                                                    <span class="d-block mb-1">@se.Start.ToString("MMM dd HH:mm")</span>
                                                    <span class="d-block mb-1 text-muted" style="font-size: 0.9em; max-width: 200px; white-space: normal;">@se.Description</span>
                                                    <span>Duration: <strong>@FormatAsHours(se.Hours)</strong></span>
                                                </div>
                                            }
                                        </TooltipTemplate>
                                    </RadzenLineSeries>
                                }
                                <RadzenCategoryAxis Formatter="@FormatProjectAxis">
                                    <RadzenGridLines Visible="false" />
                                    <RadzenAxisTitle Text="Project" />
                                </RadzenCategoryAxis>
                                <RadzenValueAxis Formatter="@FormatAsHours">
                                    <RadzenGridLines Visible="true" />
                                    <RadzenAxisTitle Text="Hours Logged" />
                                </RadzenValueAxis>
                                <RadzenLegend Position="LegendPosition.Bottom" />
                            </RadzenChart>
                        }
                        else
                        {
                            <RadzenChart Style="width:100%; height:100%;">
                                @foreach (var projectName in ChartData.Select(d => d.ProjectName).Distinct())
                                {
                                    @if (SelectedChartType == 1)
                                    {
                                        <RadzenStackedColumnSeries Data="@ChartData.Where(d => d.ProjectName == projectName)" 
                                                                   CategoryProperty="Date" 
                                                                   Title="@projectName" 
                                                                   ValueProperty="Hours">
                                            <TooltipTemplate Context="data">
                                                @{
                                                    var dph = (DailyProjectHours)data;
                                                    var dayRecords = ChartData.Where(x => x.Date == dph.Date).ToList();
                                                    <div style="padding: 5px;">
                                                        <strong style="display: block; margin-bottom: 5px;">@dph.Date.ToString("MMM dd, yyyy")</strong>
                                                        <ul class="mb-0 ps-3" style="font-size: 0.9em; margin: 0; padding-left: 15px;">
                                                        @foreach(var r in dayRecords.OrderByDescending(x => x.Hours))
                                                        {
                                                            <li>@r.ProjectName: @FormatAsHours(r.Hours)</li>
                                                        }
                                                        </ul>
                                                    </div>
                                                }
                                            </TooltipTemplate>
                                        </RadzenStackedColumnSeries>
                                    }
                                    else if (SelectedChartType == 2)
                                    {
                                        <RadzenLineSeries Data="@ChartData.Where(d => d.ProjectName == projectName)" 
                                                          CategoryProperty="Date" 
                                                          Title="@projectName" 
                                                          ValueProperty="Hours">
                                            <ChildContent>
                                                <RadzenMarkers MarkerType="MarkerType.Circle" Visible="@ShowMarkers" />
                                            </ChildContent>
                                            <TooltipTemplate Context="data">
                                                @{
                                                    var dph = (DailyProjectHours)data;
                                                    var dayRecords = ChartData.Where(x => x.Date == dph.Date).ToList();
                                                    <div style="padding: 5px;">
                                                        <strong style="display: block; margin-bottom: 5px;">@dph.Date.ToString("MMM dd, yyyy")</strong>
                                                        <ul class="mb-0 ps-3" style="font-size: 0.9em; margin: 0; padding-left: 15px;">
                                                        @foreach(var r in dayRecords.OrderByDescending(x => x.Hours))
                                                        {
                                                            <li>@r.ProjectName: @FormatAsHours(r.Hours)</li>
                                                        }
                                                        </ul>
                                                    </div>
                                                }
                                            </TooltipTemplate>
                                        </RadzenLineSeries>
                                    }
                                    else if (SelectedChartType == 4)
                                    {
                                        <RadzenStackedAreaSeries Data="@ChartData.Where(d => d.ProjectName == projectName)" 
                                                                 CategoryProperty="Date" 
                                                                 Title="@projectName" 
                                                                 ValueProperty="Hours">
                                            <ChildContent>
                                                <RadzenMarkers MarkerType="MarkerType.Circle" Visible="@ShowMarkers" />
                                            </ChildContent>
                                            <TooltipTemplate Context="data">
                                                @{
                                                    var dph = (DailyProjectHours)data;
                                                    var dayRecords = ChartData.Where(x => x.Date == dph.Date).ToList();
                                                    <div style="padding: 5px;">
                                                        <strong style="display: block; margin-bottom: 5px;">@dph.Date.ToString("MMM dd, yyyy")</strong>
                                                        <ul class="mb-0 ps-3" style="font-size: 0.9em; margin: 0; padding-left: 15px;">
                                                        @foreach(var r in dayRecords.OrderByDescending(x => x.Hours))
                                                        {
                                                            <li>@r.ProjectName: @FormatAsHours(r.Hours)</li>
                                                        }
                                                        </ul>
                                                    </div>
                                                }
                                            </TooltipTemplate>
                                        </RadzenStackedAreaSeries>
                                    }
                                }
                                <RadzenColumnOptions Radius="5" />
                                <RadzenValueAxis Formatter="@FormatAsHours">
                                    <RadzenGridLines Visible="true" />
                                    <RadzenAxisTitle Text="Hours Worked" />
                                </RadzenValueAxis>
                                <RadzenCategoryAxis FormatString="{0:MMM dd}">
                                    <RadzenAxisTitle Text="Date" />
                                </RadzenCategoryAxis>
                                <RadzenLegend Position="LegendPosition.Bottom" />
                            </RadzenChart>
                        }
                    </div>
                </div>
                <div class="d-flex justify-content-between align-items-center mt-2 px-2">
                    <span class="text-muted" style="font-size:0.8rem;">Note: Pinch or scroll to stretch horizontal view.</span>
                    <div>
                        <button class="btn btn-sm btn-outline-secondary me-2" title="Zoom Out" @onclick="() => OnChartZoom(100)"><i class="bi bi-zoom-out"></i></button>
                        <button class="btn btn-sm btn-outline-secondary me-2" title="Reset Zoom" @onclick="() => ChartWidthPercent = 100">Reset</button>
                        <button class="btn btn-sm btn-outline-secondary" title="Zoom In" @onclick="() => OnChartZoom(-100)"><i class="bi bi-zoom-in"></i></button>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Description</th>
                    <th>Start</th>
                    <th>Duration</th>
                    <th>Project</th>
                    <th>Client</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var entry in TimeEntries)
                {
                    <tr>
                        <td>@entry.Description</td>
                        <td>@entry.Start.ToLocalTime().ToString("g")</td>
                        <td>@entry.GetDuration().ToString(@"hh\:mm\:ss")</td>
                        <td>@GetProjectName(entry.ProjectId)</td>
                        <td>@GetClientName(entry.ProjectId)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    public class DailyProjectHours
    {
        public DateTime Date { get; set; }
        public double Hours { get; set; }
        public string ProjectName { get; set; } = string.Empty;
    }

    public class ProjectSummaryHours
    {
        public string ProjectName { get; set; } = string.Empty;
        public double TotalHours { get; set; }
    }

    public class ScatterEntry
    {
        public string ProjectName { get; set; } = string.Empty;
        public int ProjectIndex { get; set; }
        public double XOffset { get; set; }
        public double Hours { get; set; }
        public DateTime Start { get; set; }
        public string Description { get; set; } = string.Empty;
    }

    private bool IsLoading = false;
    private int SelectedChartType = 1;
    private string SelectedTimeframe = "LastWeek";

    private DateTime StartDate;
    private DateTime EndDate;
    private List<TimeEntry>? TimeEntries;
    private List<DailyProjectHours> ChartData = new();
    private List<ProjectSummaryHours> PieChartData = new();
    private List<ScatterEntry> ScatterChartData = new();
    private Dictionary<int, string> ProjectIndexToName = new();
    private Dictionary<long, Project> Projects = new();
    private Dictionary<long, Client> Clients = new();

    private int ChartWidthPercent = 100;
    private DotNetObjectReference<Analysis>? objRef;

    private bool ShowMarkers => ChartData.Select(d => d.Date).Distinct().Count() <= 30;

    private void OnCustomDateChanged()
    {
        SelectedTimeframe = "Custom";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            objRef = DotNetObjectReference.Create(this);
            var js = @"
                window.setupChartZoom = function(id, dotNetHelper) {
                    var el = document.getElementById(id);
                    if (!el) return;
                    el.addEventListener('wheel', function(e) {
                        if (e.ctrlKey) {
                            e.preventDefault();
                            dotNetHelper.invokeMethodAsync('OnChartZoom', e.deltaY);
                        }
                    }, { passive: false });
                };
            ";
            await JSRuntime.InvokeVoidAsync("eval", js);
            await JSRuntime.InvokeVoidAsync("setupChartZoom", "chart-scroll-wrapper", objRef);
        }
    }

    [JSInvokable]
    public void OnChartZoom(double deltaY)
    {
        if (deltaY < 0) {
            ChartWidthPercent += 20; 
            if (ChartWidthPercent > 2000) ChartWidthPercent = 2000;
        } else {
            ChartWidthPercent -= 20; 
            if (ChartWidthPercent < 100) ChartWidthPercent = 100;
        }
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (objRef != null)
        {
            objRef.Dispose();
            objRef = null;
        }
    }

    private void SetTimeframe(string timeframe)
    {
        SelectedTimeframe = timeframe;
        var today = DateTime.Today;
        switch (timeframe)
        {
            case "LastWeek":
                var diff = today.DayOfWeek == DayOfWeek.Sunday ? 7 : (int)today.DayOfWeek;
                StartDate = today.AddDays(-diff - 6);
                EndDate = StartDate.AddDays(6);
                break;
            case "LastMonth":
                StartDate = new DateTime(today.Year, today.Month, 1).AddMonths(-1);
                EndDate = new DateTime(today.Year, today.Month, DateTime.DaysInMonth(StartDate.Year, StartDate.Month));
                break;
            case "LastQuarter":
                int quarter = (today.Month - 1) / 3 + 1;
                StartDate = new DateTime(today.Year, 3 * quarter - 2, 1).AddMonths(-3);
                EndDate = StartDate.AddMonths(3).AddDays(-1);
                break;
            case "ThisYear":
                StartDate = new DateTime(today.Year, 1, 1);
                EndDate = new DateTime(today.Year, 12, 31);
                break;
        }
    }

    private async Task ApplyTimeframe()
    {
        ChartWidthPercent = 100;
        await LoadData();
    }

    private async Task OnTimeframeSelectChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        if (!string.IsNullOrEmpty(val))
        {
            SetTimeframe(val);
            if (val != "Custom")
            {
                await ApplyTimeframe();
            }
        }
    }

    private async Task ShiftPrev()
    {
        var duration = EndDate - StartDate;
        if (SelectedTimeframe == "LastMonth")
        {
            StartDate = StartDate.AddMonths(-1);
            EndDate = new DateTime(StartDate.Year, StartDate.Month, DateTime.DaysInMonth(StartDate.Year, StartDate.Month));
        }
        else if (SelectedTimeframe == "LastQuarter")
        {
            StartDate = StartDate.AddMonths(-3);
            EndDate = StartDate.AddMonths(3).AddDays(-1);
        }
        else if (SelectedTimeframe == "ThisYear")
        {
            StartDate = StartDate.AddYears(-1);
            EndDate = StartDate.AddYears(1).AddDays(-1);
        }
        else
        {
            int days = (int)Math.Round(duration.TotalDays) + 1;
            StartDate = StartDate.AddDays(-days);
            EndDate = EndDate.AddDays(-days);
        }
        await ApplyTimeframe();
    }

    private async Task ShiftNext()
    {
        var duration = EndDate - StartDate;
        if (SelectedTimeframe == "LastMonth")
        {
            StartDate = StartDate.AddMonths(1);
            EndDate = new DateTime(StartDate.Year, StartDate.Month, DateTime.DaysInMonth(StartDate.Year, StartDate.Month));
        }
        else if (SelectedTimeframe == "LastQuarter")
        {
            StartDate = StartDate.AddMonths(3);
            EndDate = StartDate.AddMonths(3).AddDays(-1);
        }
        else if (SelectedTimeframe == "ThisYear")
        {
            StartDate = StartDate.AddYears(1);
            EndDate = StartDate.AddYears(1).AddDays(-1);
        }
        else
        {
            int days = (int)Math.Round(duration.TotalDays) + 1;
            StartDate = StartDate.AddDays(days);
            EndDate = EndDate.AddDays(days);
        }
        await ApplyTimeframe();
    }

    protected override async Task OnInitializedAsync()
    {
        SetTimeframe("LastWeek");
        await LoadData();
    }

    private async Task OnChartTypeChanged(int newType)
    {
        IsLoading = true;
        StateHasChanged();
        
        // Yield to let the UI render the loading spinner
        await Task.Delay(10);
        
        SelectedChartType = newType;
        
        IsLoading = false;
        StateHasChanged();
    }

    private async Task LoadData()
    {
        IsLoading = true;
        StateHasChanged();
        await Task.Delay(1); // Force UI update

        try
        {
            TimeEntries = await TogglService.GetLocalTimeEntriesAsync(StartDate, EndDate);

            if (TogglService.HasApiKey)
            {
                await TogglService.SyncMetadataAsync();
            }

            // Fetch local projects from DB
            var localProjects = await DbContext.Projects.ToListAsync();
            foreach(var p in localProjects)
            {
                if (!Projects.ContainsKey(p.Id)) Projects[p.Id] = p;
            }

            // Fetch clients if we have an API key
            if (TogglService.HasApiKey)
            {
                var workspaces = await TogglService.FetchWorkspacesAsync();
                foreach (var ws in workspaces)
                {
                    var clients = await TogglService.FetchClientsAsync(ws.Id);
                    foreach (var c in clients)
                    {
                        if (!Clients.ContainsKey(c.Id))
                        {
                            Clients[c.Id] = c;
                        }
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching data: {ex.Message}");
        }
        finally
        {
            if (TimeEntries != null)
            {
                ChartData = TimeEntries
                    .GroupBy(t => new { Date = t.Start.ToLocalTime().Date, ProjectId = t.ProjectId })
                    .Select(g => new DailyProjectHours
                    {
                        Date = g.Key.Date,
                        ProjectName = GetProjectName(g.Key.ProjectId),
                        Hours = g.Sum(t => t.GetDuration().TotalHours)
                    })
                    .OrderBy(d => d.Date)
                    .ToList();

                PieChartData = ChartData
                    .GroupBy(d => d.ProjectName)
                    .Select(g => new ProjectSummaryHours
                    {
                        ProjectName = g.Key,
                        TotalHours = g.Sum(x => x.Hours)
                    })
                    .OrderByDescending(p => p.TotalHours)
                    .ToList();

                var distinctProjects = ChartData.Select(d => d.ProjectName).Distinct().ToList();
                for (int i = 0; i < distinctProjects.Count; i++) {
                    ProjectIndexToName[i] = distinctProjects[i];
                }
                var projectNameToIndex = distinctProjects.Select((name, index) => new { name, index }).ToDictionary(x => x.name, x => x.index);

                ScatterChartData = TimeEntries.Select(t => {
                    var projName = GetProjectName(t.ProjectId);
                    var pIndex = projectNameToIndex.ContainsKey(projName) ? projectNameToIndex[projName] : 0;
                    
                    var hourFraction = t.Start.ToLocalTime().TimeOfDay.TotalHours / 24.0;
                    var jitter = (hourFraction - 0.5) * 0.8; 
                    
                    return new ScatterEntry
                    {
                        ProjectName = projName,
                        ProjectIndex = pIndex,
                        XOffset = pIndex + jitter,
                        Hours = t.GetDuration().TotalHours,
                        Start = t.Start.ToLocalTime(),
                        Description = t.Description ?? "(no description)"
                    };
                }).ToList();
            }

            IsLoading = false;
            StateHasChanged();
        }
    }

    private string FormatProjectAxis(object value)
    {
        try 
        {
            double d = Convert.ToDouble(value);
            int idx = (int)Math.Round(d);
            if (ProjectIndexToName.TryGetValue(idx, out var name)) 
            {
                if (Math.Abs(d - idx) < 0.1) return name;
            }
        }
        catch { }
        return string.Empty;
    }

    private string FormatAsHours(object value)
    {
        if (value is double hours)
        {
            return $"{hours:F1}h";
        }
        return value?.ToString() ?? string.Empty;
    }

    private string GetProjectName(long? projectId)
    {
        if (projectId.HasValue && Projects.TryGetValue(projectId.Value, out var project))
        {
            return project.Name;
        }
        return projectId?.ToString() ?? "-";
    }

    private string GetClientName(long? projectId)
    {
        if (projectId.HasValue && Projects.TryGetValue(projectId.Value, out var project))
        {
            if (project.ClientId.HasValue && Clients.TryGetValue(project.ClientId.Value, out var client))
            {
                return client.Name;
            }
        }
        return "-";
    }
}
